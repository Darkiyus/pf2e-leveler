{
  "id": "darkis-better-pf2e-leveler",
  "title": "Darkis Better PF2e-Leveler",
  "description": "Guided character creation and level-up planning for Pathfinder 2E and Starfinder 2E, with GM campaign tools, quick-equipment packages, and an optional German interface.",
  "version": "3.10.0",
  "license": "LICENSE",
  "socket": true,
  "compatibility": {
    "minimum": "13",
    "verified": "14"
  },
  "authors": [
    {
      "name": "RoiLeaf",
      "discord": "RoiLeaf",
      "flags": {}
    },
    {
      "name": "Darkiyus",
      "url": "https://github.com/Darkiyus/Darkis-Better-PF2e-Leveler",
      "flags": {}
    }
  ],
  "esmodules": ["scripts/main.js"],
  "styles": [
    {
      "src": "styles/variables.css"
    },
    {
      "src": "styles/components.css"
    },
    {
      "src": "styles/level-planner.css"
    },
    {
      "src": "styles/compendium-picker.css"
    },
    {
      "src": "styles/character-wizard.css"
    },
    {
      "src": "styles/quick-equipment-packages.css"
    },
    {
      "src": "styles/gm-setup-wizard.css"
    },
    {
      "src": "styles/image-zoom.css"
    },
    {
      "src": "styles/credits-menu.css"
    },
    {
      "src": "styles/theme.css"
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json",
      "flags": {}
    },
    {
      "lang": "fr",
      "name": "Fran\u00e7ais",
      "path": "lang/fr.json",
      "flags": {}
    },
    {
      "lang": "de",
      "name": "Deutsch",
      "path": "lang/de.json",
      "flags": {}
    },
    {
      "lang": "cn",
      "name": "\u7b80\u4f53\u4e2d\u6587",
      "path": "lang/cn.json",
      "flags": {}
    }
  ],
  "flags": {
    "hotReload": {
      "extensions": ["css", "hbs", "json"],
      "paths": ["styles", "templates", "lang"]
    }
  },
  "relationships": {
    "recommends": [
      {
        "id": "socketlib",
        "type": "module",
        "reason": "Reliable GM delivery of player review requests; falls back to GM whispers if absent."
      }
    ],
    "systems": [
      {
        "id": "pf2e",
        "type": "system",
        "compatibility": {
          "minimum": "7.0.0",
          "verified": "8.3.0"
        }
      },
      {
        "id": "sf2e",
        "type": "system",
        "compatibility": {
          "minimum": "0.0.10",
          "verified": "1.0.1"
        }
      }
    ]
  },
  "url": "#{URL}#",
  "manifest": "#{MANIFEST}#",
  "download": "#{DOWNLOAD}#"
}
