{
  "id": "darkis-better-pf2e-leveler",
  "title": "Darkis Better PF2e-Leveler",
  "description": "<p><strong>Darkis Better PF2e-Leveler</strong> is a guided character-creation and level-up planning assistant for Pathfinder Second Edition and Starfinder Second Edition.</p><p>It is an independent fork of RoiLeaf's original <em>PF2e Leveler</em>, rebuilt for smoother performance on large compendiums with an optional German interface and expanded GM tools: a first-run campaign setup assistant, content guidance for ancestries, heritages, backgrounds, classes, and feats, reusable quick-equipment packages, campaign-profile import/export, and a gallery view with image hover-zoom for browsing options.</p><p>Interface languages: English, German, French, and Simplified Chinese.</p>",
  "version": "3.9.1",
  "license": "LICENSE",
  "socket": true,
  "compatibility": {
    "minimum": "13",
    "verified": "14"
  },
  "authors": [
    {
      "name": "RoiLeaf",
      "discord": "RoiLeaf",
      "flags": {}
    },
    {
      "name": "Darkiyus",
      "url": "https://github.com/Darkiyus/Darkis-Better-PF2e-Leveler",
      "flags": {}
    }
  ],
  "esmodules": ["scripts/main.js"],
  "styles": [
    {
      "src": "styles/variables.css"
    },
    {
      "src": "styles/components.css"
    },
    {
      "src": "styles/level-planner.css"
    },
    {
      "src": "styles/compendium-picker.css"
    },
    {
      "src": "styles/character-wizard.css"
    },
    {
      "src": "styles/quick-equipment-packages.css"
    },
    {
      "src": "styles/gm-setup-wizard.css"
    },
    {
      "src": "styles/image-zoom.css"
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json",
      "flags": {}
    },
    {
      "lang": "fr",
      "name": "Fran\u00e7ais",
      "path": "lang/fr.json",
      "flags": {}
    },
    {
      "lang": "de",
      "name": "Deutsch",
      "path": "lang/de.json",
      "flags": {}
    },
    {
      "lang": "cn",
      "name": "\u7b80\u4f53\u4e2d\u6587",
      "path": "lang/cn.json",
      "flags": {}
    }
  ],
  "flags": {
    "hotReload": {
      "extensions": ["css", "hbs", "json"],
      "paths": ["styles", "templates", "lang"]
    }
  },
  "relationships": {
    "recommends": [
      {
        "id": "socketlib",
        "type": "module",
        "reason": "Reliable GM delivery of player review requests; falls back to GM whispers if absent."
      }
    ],
    "systems": [
      {
        "id": "pf2e",
        "type": "system",
        "compatibility": {
          "minimum": "7.0.0",
          "verified": "8.3.0"
        }
      },
      {
        "id": "sf2e",
        "type": "system",
        "compatibility": {
          "minimum": "0.0.10",
          "verified": "1.0.1"
        }
      }
    ]
  },
  "url": "#{URL}#",
  "manifest": "#{MANIFEST}#",
  "download": "#{DOWNLOAD}#"
}
